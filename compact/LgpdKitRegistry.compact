/**
 * LgpdKitRegistry Contract (Midnight Network)
 * Anti-Fraud Registry for LGPD Kit Generated Documents
 *
 * Verifies and stores cryptographic proofs of DPO2U LGPD compliance documents
 * (DPIA and Privacy Policy) generated by LLMs, ensuring immutability against retroactive tampering.
 */
pragma language_version >= 0.19;
import CompactStandardLibrary;

export ledger kit_dpia_hashes: Map<Bytes<32>, Bytes<32>>;
export ledger kit_policy_hashes: Map<Bytes<32>, Bytes<32>>;
export ledger kit_privacy_scores: Map<Bytes<32>, Uint<64>>;
export ledger kit_auditor_dids: Map<Bytes<32>, Bytes<32>>;

export circuit registerLgpdKit(
    company_id: Bytes<32>,
    dpia_hash: Bytes<32>,
    policy_hash: Bytes<32>,
    score: Uint<64>,
    auditor_did: Bytes<32>
): [] {
    // Zero-Knowledge validations
    assert(score <= 100, "Invalid compliance score, must be bounded to 0-100%");

    // Commit the hashes and signatures to the public ledger
    kit_dpia_hashes.insert(disclose(company_id), disclose(dpia_hash));
    kit_policy_hashes.insert(disclose(company_id), disclose(policy_hash));
    kit_privacy_scores.insert(disclose(company_id), disclose(score));
    kit_auditor_dids.insert(disclose(company_id), disclose(auditor_did));
}

export circuit getCompanyPrivacyScore(company_id: Bytes<32>): Uint<64> {
    // Usar member() antes de lookup() para seguranca
    if (kit_privacy_scores.member(disclose(company_id))) {
        return kit_privacy_scores.lookup(disclose(company_id));
    } else {
        return 0;
    }
}
